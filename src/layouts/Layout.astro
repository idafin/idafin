---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "idafin — Sermayenin doğru kararı",
  description = "idafin, kurumsal müşterilere finansal danışmanlık, yazılım ve süreç dönüşümü hizmeti veren bağımsız bir İstanbul danışmanlık şirketidir.",
} = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-paper text-ink font-sans">
    <slot />
  </body>
</html>
