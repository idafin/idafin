---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/sections/Nav.astro";
import Footer from "../components/sections/Footer.astro";
---

<Layout
  title="Gizlilik Politikası — idafin"
  description="idafin gizlilik politikası ve kişisel veri işleme esasları."
>
  <Nav />
  <main class="bg-paper border-b border-ink py-20 md:py-30">
    <div class="container-site grid-12">
      <div class="col-span-12 md:col-span-2">
        <div class="text-mono-cap text-ink-muted">—</div>
        <div class="mt-3 text-mono-cap text-ink">GİZLİLİK</div>
      </div>
      <div class="col-span-12 md:col-span-8">
        <h1 class="text-display m-0 text-ink mb-12">Gizlilik Politikası</h1>
        <div class="prose-content text-[17px] leading-[1.7] text-ink-soft space-y-6">
          <p>
            Bu sayfa, ileride yayımlanacak gizlilik politikası için yer tutucudur.
            Politika metni hazır olduğunda burada yayımlanacaktır.
          </p>
          <p>
            Sorularınız için <a href="mailto:iletisim@idafin.com" class="text-accent">iletisim@idafin.com</a>
            adresine ulaşabilirsiniz.
          </p>
          <p class="font-mono text-[11px] tracking-[0.12em] uppercase text-ink-muted pt-8">
            Son güncelleme: —
          </p>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
