---
import insightsData from "../../data/insights.json";

const posts = [...insightsData].sort((a, b) => a.order - b.order);
---

<section id="insights" class="bg-paper-alt border-b border-ink py-20 md:py-30">
  <div class="container-site grid-12 gap-y-10">
    <div class="col-span-12 md:col-span-2">
      <div class="text-mono-cap text-ink-muted">05</div>
      <div class="mt-3 text-mono-cap text-ink">YAZILAR</div>
    </div>
    <div class="col-span-12 md:col-span-10">
      <div class="flex justify-between items-end mb-12">
        <h2 class="text-display m-0">Güncel.</h2>
        <a
          href="#"
          class="text-sm font-semibold text-ink no-underline border-b-2 border-accent pb-1"
          >Tüm yazılar →</a
        >
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 border-t border-ink pt-8">
        {
          posts.map((p, i) => (
            <a href="#" class="no-underline text-ink flex flex-col">
              <div
                class="aspect-[4/3] bg-paper border border-line relative overflow-hidden"
                style={`background-image: repeating-linear-gradient(${45 + i * 30}deg, rgba(10,10,10,0.12) 0 1px, transparent 1px 14px);`}
              >
                <div class="absolute top-3 left-3 px-2.5 py-1 bg-accent text-paper font-mono text-[10px] tracking-[0.12em] uppercase">
                  {p.category}
                </div>
              </div>
              <div class="mt-4 font-mono text-[11px] tracking-[0.12em] text-ink-muted uppercase">
                {p.date} · {p.readMinutes} dk okuma
              </div>
              <h3 class="text-[22px] font-semibold leading-[1.2] tracking-[-0.02em] mt-2 m-0">
                {p.title}
              </h3>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
