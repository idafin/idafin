---
import { getCollection } from "astro:content";

const cases = (await getCollection("cases")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="cases" class="bg-paper border-b border-ink py-20 md:py-30">
  <div class="container-site grid-12 gap-y-10">
    <div class="col-span-12 md:col-span-2">
      <div class="text-mono-cap text-ink-muted">04</div>
      <div class="mt-3 text-mono-cap text-ink">ÇALIŞMALAR</div>
    </div>
    <div class="col-span-12 md:col-span-10">
      <h2 class="text-display m-0 text-ink mb-12">Sayılarla konuşan sonuçlar.</h2>
      <div class="border-t border-ink">
        {
          cases.map((c) => (
            <a
              href="#"
              class="grid grid-cols-2 md:grid-cols-[80px_120px_1fr_220px_100px] gap-6 py-8 border-b border-ink items-center text-ink no-underline hover:bg-paper-alt transition-colors px-2"
            >
              <div class="font-mono text-[11px] tracking-[0.12em] text-ink-muted">{c.data.year}</div>
              <div class="font-mono text-[11px] tracking-[0.12em] text-ink">{c.data.sector}</div>
              <div class="col-span-2 md:col-span-1 text-[22px] font-semibold tracking-[-0.02em]">
                {c.data.title}
              </div>
              <div>
                <div class="text-[32px] font-bold tracking-[-0.03em] text-accent leading-none">
                  {c.data.metric}
                </div>
                <div class="font-mono text-[10px] tracking-[0.12em] text-ink-muted mt-1 uppercase">
                  {c.data.metricLabel}
                </div>
              </div>
              <div class="text-sm font-semibold text-right hidden md:block">Oku →</div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
